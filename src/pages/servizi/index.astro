---
import Layout from '../../layouts/Layout.astro';
import { services } from '../../data/services';

const title = "I Nostri Servizi | Tende, Divani e Materassi a Castellanza";
const description = "Scopri tutti i servizi della Casa del Salotto: tende su misura, rifacimento divani, tappezzeria, materassi e tessuti d'arredo a Castellanza (VA).";
---

<Layout title={title} description={description}>
  <section class="page-header bg-light">
    <div class="container text-center">
      <h1>I Nostri Servizi Artigianali</h1>
      <p>Soluzioni su misura per arredare la tua casa con stile e qualità.</p>
    </div>
  </section>

  <section class="section-services-grid">
    <div class="container">
      <div class="grid grid-3">
        {services.map(service => (
          <a href={`/servizi/${service.id}`} class="service-card">
            <div class="card-image">
               <img 
                 src={`/assets/${service.id}-img-01.jpg`} 
                 alt={service.title}
                 onerror="this.src='https://placehold.co/600x400?text=Servizio'"
               />
            </div>
            <div class="card-content">
              <h3>{service.title}</h3>
              <p>{service.shortDescription}</p>
              <span class="btn-link">Scopri di più &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
  
  <section class="section-cta container text-center mb-5">
      <div class="bg-light p-4 rounded border">
          <h3>Non trovi quello che cerchi?</h3>
          <p>Realizziamo progetti personalizzati. Contattaci per esporci la tua idea.</p>
          <a href="/contatti" class="btn">Parla con noi</a>
      </div>
  </section>
</Layout>

<style>
  .page-header { padding: 4rem 0; }
  
  .service-card {
    display: block;
    border: 1px solid #eee;
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s;
    background: white;
  }
  
  .service-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }
  
  .card-image img {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }
  
  .card-content {
    padding: 1.5rem;
  }
  
  .card-content h3 {
    color: var(--primary);
    margin-bottom: 0.5rem;
  }
  
  .btn-link {
    color: var(--primary);
    font-weight: 600;
    margin-top: 1rem;
    display: inline-block;
  }
  
  .rounded { border-radius: 8px; }
  .border { border: 1px solid #eee; }
  .p-4 { padding: 2rem; }
  .mb-5 { margin-bottom: 3rem; }
</style>
