---
// Loader.astro
---

<div id="page-loader" class="loader-wrapper">
    <div class="loader-content">
        <img
            src="/assets/Logo-casadelsalotto.png"
            alt="Casa del Salotto"
            class="loader-logo"
        />
        <div class="spinner"></div>
    </div>
</div>

<script>
    // Script runs on client side
    document.addEventListener("astro:page-load", () => {
        const loader = document.getElementById("page-loader");
        if (loader && !sessionStorage.getItem("hasSeenLoader")) {
            // First visit: show loader for 1.2s then fade out
            setTimeout(() => {
                loader.classList.add("fade-out");
                sessionStorage.setItem("hasSeenLoader", "true");

                // Remove from DOM after transition
                setTimeout(() => {
                    loader.style.display = "none";
                }, 500);
            }, 1200);
        } else if (loader) {
            // Already seen or navigating: hide immediately
            loader.style.display = "none";
        }
    });
</script>

<style>
    .loader-wrapper {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: var(--bg);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        transition: opacity 0.5s ease-in-out;
    }

    .loader-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
    }

    .loader-logo {
        width: 280px;
        height: auto;
        animation: pulse 2s infinite ease-in-out;
    }

    .loader-wrapper.fade-out {
        opacity: 0;
        pointer-events: none;
    }

    .spinner {
        width: 50px;
        height: 50px;
        border: 4px solid rgba(161, 38, 68, 0.2); /* Light version of #A12644 */
        border-top: 4px solid var(--primary); /* Solid #A12644 */
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @keyframes spin {
        0% {
            transform: rotate(0deg);
        }
        100% {
            transform: rotate(360deg);
        }
    }

    @keyframes pulse {
        0% {
            opacity: 0.8;
            transform: scale(0.98);
        }
        50% {
            opacity: 1;
            transform: scale(1);
        }
        100% {
            opacity: 0.8;
            transform: scale(0.98);
        }
    }
</style>
