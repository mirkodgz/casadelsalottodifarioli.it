---
import Layout from '../../layouts/Layout.astro';
import ServiceCarousel from '../../components/ServiceCarousel.astro';
import { services } from '../../data/services';

export async function getStaticPaths() {
  return services.map(service => ({
    params: { slug: service.id },
    props: { service },
  }));
}

const { service } = Astro.props;
---

<Layout title={service.metaTitle} description={service.metaDescription}>
  
  <!-- HERO SERVICE -->
  <section class="service-hero bg-light">
    <div class="container text-center">
      <h1>{service.title}</h1>
      <p class="service-lead">{service.shortDescription}</p>
    </div>
  </section>

  <div class="container main-content-grid">
    <div class="content-col">
       <!-- CAROUSEL -->
       <ServiceCarousel serviceId={service.id} altPrefix={service.title} count={service.imageCount} />

       <!-- DESCRIPTION -->
       <div class="article-content" set:html={service.fullDescription} />

       <!-- FEATURES -->
       <div class="features-box">
         <h3>Perché scegliere il nostro servizio {service.title}?</h3>
         <ul class="features-list">
           {service.features.map(feature => (
             <li>{feature}</li>
           ))}
         </ul>
       </div>

    </div>

    <!-- SIDEBAR -->
    <aside class="sidebar">
      <div class="sidebar-box contact-box">
        <h3>Richiedi Informazioni</h3>
        <p>Siamo a tua disposizione per un preventivo gratuito.</p>
        <a href="/contatti#preventivo" class="btn btn-full mb-2">Richiedi Preventivo</a>
        <a href="https://api.whatsapp.com/send/?phone=393803104932" class="btn btn-whatsapp btn-full">WhatsApp</a>
      </div>

      <div class="sidebar-box">
        <h3>Altri Servizi</h3>
        <ul class="sidebar-nav">
          {services.filter(s => s.id !== service.id).map(s => (
            <li><a href={`/servizi/${s.id}`}>{s.title}</a></li>
          ))}
        </ul>
      </div>
    </aside>
  </div>
  
  <section class="final-cta text-center container">
      <h2>Pronto a iniziare?</h2>
      <a href="/contatti" class="btn">Contattaci Subito</a>
  </section>

</Layout>

<style>
  .service-hero { padding: 3rem 0; margin-bottom: 2rem; }
  .service-hero h1 { color: var(--primary); margin-bottom: 1rem; }
  .service-lead { font-size: 1.2rem; color: #555; max-width: 800px; margin: 0 auto; }

  .main-content-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding-bottom: 4rem;
  }

  /* Article Prose */
  .article-content {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #333;
    margin-bottom: 2rem;
  }
  /* Target global CSS prose styles if needed, or define specific h3/ul here */
  .article-content :global(h3) { margin-top: 2rem; color: var(--primary); }
  .article-content :global(ul) { margin: 1rem 0; padding-left: 1.5rem; list-style: circle; }
  .article-content :global(li) { margin-bottom: 0.5rem; }

  /* Features */
  .features-box {
    background: #fdfdfd;
    border: 1px solid #eee;
    padding: 2rem;
    border-radius: 8px;
    border-left: 4px solid var(--primary);
  }
  .features-list { list-style: none; padding: 0; display: grid; grid-template-columns: 1fr; gap: 0.5rem; margin-top: 1rem; }
  .features-list li::before {
    content: '✓';
    color: var(--primary);
    font-weight: bold;
    margin-right: 0.5rem;
  }
  @media (min-width: 600px) {
    .features-list { grid-template-columns: 1fr 1fr; }
  }

  /* Process */
  .process-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }
  .step {
    background: var(--bg-light);
    padding: 1rem;
    border-radius: 4px;
  }
  @media (min-width: 600px) {
    .process-steps { grid-template-columns: 1fr 1fr; }
  }

  /* FAQ */
  .faq-item {
    margin-bottom: 1rem;
    border-bottom: 1px solid #eee;
    padding-bottom: 1rem;
  }
  .faq-item summary { font-weight: 600; cursor: pointer; color: var(--primary); }

  /* Sidebar */
  .sidebar-box {
    background: var(--bg-light);
    padding: 1.5rem;
    border-radius: 8px;
    margin-bottom: 2rem;
  }
  .sidebar-box h3 { font-size: 1.2rem; margin-bottom: 1rem; border-bottom: 2px solid #ddd; padding-bottom: 0.5rem; }
  .btn-full { display: block; text-align: center; width: 100%; }
  .mb-2 { margin-bottom: 1rem; }
  .btn-whatsapp { background-color: #25d366; border-color: #25d366; }
  
  .sidebar-nav { list-style: none; padding: 0; }
  .sidebar-nav li { margin-bottom: 0.5rem; border-bottom: 1px solid #eee; padding-bottom: 0.5rem; }
  .sidebar-nav a:hover { color: var(--primary); padding-left: 5px; }

  @media (min-width: 900px) {
    .main-content-grid {
      grid-template-columns: 2fr 1fr;
    }
    .service-hero { padding: 5rem 0; }
  }
  
  .mt-5 { margin-top: 3rem; }
  .final-cta { padding: 4rem 0; }
</style>
